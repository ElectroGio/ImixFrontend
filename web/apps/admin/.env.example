# URL nginx uses to reach the backend API. When both the backend stack and
# the admin stack are attached to dokploy-network, the backend service `api`
# from imix-backend/docker-compose.yml is reachable by its service name.
# If Dokploy renamed the service (e.g. `api-<suffix>`), put that hostname here.
API_UPSTREAM=http://api:8080

# Host port to expose the SPA on (Dokploy usually routes via Traefik instead).
ADMIN_PORT=8081
