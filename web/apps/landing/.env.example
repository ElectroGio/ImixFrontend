# URL nginx uses to reach the backend API. When both the backend stack and
# the landing stack are attached to dokploy-network, the backend service `api`
# from imix-backend/docker-compose.yml is reachable by its service name.
API_UPSTREAM=http://api:8080

# In Dokploy, configure the domain (e.g. clients.imixnes.com) with
# Container Port = 80. No host port mapping is needed.
